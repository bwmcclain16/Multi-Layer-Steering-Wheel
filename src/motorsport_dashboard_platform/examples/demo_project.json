{
  "alerts": [
    {
      "alert_id": "rpm-high",
      "cooldown_ms": 500,
      "message": "RPM high: {value:.0f}",
      "name": "High RPM",
      "operator": ">=",
      "severity": "warning",
      "signal_id": "engine_rpm",
      "sticky": false,
      "threshold": 7800
    },
    {
      "alert_id": "battery-low",
      "cooldown_ms": 0,
      "message": "Battery voltage low: {value:.2f}V",
      "name": "Battery Low",
      "operator": "<=",
      "severity": "critical",
      "signal_id": "battery_voltage",
      "sticky": true,
      "threshold": 300.0
    }
  ],
  "assets": {
    "logo": "assets/logo.png"
  },
  "backends": [
    {
      "backend_id": "mock-primary",
      "backend_type": "mock",
      "enabled": true,
      "name": "Mock Telemetry",
      "settings": {
        "tick_ms": 250
      },
      "signal_map": {
        "gear": "gear",
        "rpm": "engine_rpm",
        "speed": "vehicle_speed"
      }
    }
  ],
  "can_buses": [
    {
      "bitrate": 500000,
      "bus_id": "vehicle_can",
      "channel": "can0",
      "description": "Primary FSAE telemetry bus",
      "name": "Vehicle CAN"
    }
  ],
  "can_mappings": [
    {
      "can_signal_id": "bms_pack_voltage_raw",
      "normalized_signal_id": "battery_voltage",
      "transform": null
    },
    {
      "can_signal_id": "vehicle_can_health_raw",
      "normalized_signal_id": "can_bus_health",
      "transform": null
    }
  ],
  "can_messages": [
    {
      "arbitration_id": 769,
      "bus_id": "vehicle_can",
      "cycle_time_ms": 20,
      "description": "Battery management system status",
      "length": 8,
      "message_id": "bms_status"
    }
  ],
  "can_signals": [
    {
      "bit_length": 16,
      "byte_order": "little_endian",
      "description": "Pack voltage from BMS",
      "maximum": 600.0,
      "message_id": "bms_status",
      "minimum": 0.0,
      "offset": 0.0,
      "scale": 0.1,
      "signal_id": "bms_pack_voltage_raw",
      "signed": false,
      "start_bit": 0,
      "timeout_ms": 100,
      "units": "V"
    },
    {
      "bit_length": 8,
      "byte_order": "little_endian",
      "description": "Percent CAN bus health",
      "maximum": 100.0,
      "message_id": "bms_status",
      "minimum": 0.0,
      "offset": 0.0,
      "scale": 1.0,
      "signal_id": "vehicle_can_health_raw",
      "signed": false,
      "start_bit": 16,
      "timeout_ms": 100,
      "units": "%"
    }
  ],
  "hardware_rules": [
    {
      "name": "Blink shift lights on high RPM",
      "output_action": "blink",
      "peripheral_id": "shift-light-bar",
      "rule_id": "shift-warning",
      "settings": {
        "color": "#ff5c39",
        "pattern": "fast"
      },
      "trigger_alert_id": "rpm-high"
    }
  ],
  "metadata": {
    "author": "OpenAI Codex",
    "description": "Example project blending sim racing and FSAE CAN telemetry.",
    "name": "MLSW Demo Motorsport Project",
    "project_id": "mlsw-demo",
    "tags": [
      "sim",
      "fsae",
      "can",
      "demo"
    ],
    "version": "0.1.0"
  },
